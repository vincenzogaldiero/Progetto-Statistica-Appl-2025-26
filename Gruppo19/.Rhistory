# Capitolo 3 - Box plot
y <- dataset$y_IQ
variabili <- c("y_IQ", "x1_ISO", "x2_T", "x3_MP",
"x4_CF", "x5_F", "x6_GSI", "x7_UA")
Q1 <- quantile(y, 0.25)
Q3 <- quantile(y, 0.75)
IQR_y <- IQR(y)
limite_inferiore <- Q1 - 1.5 * IQR_y
limite_superiore <- Q3 + 1.5 * IQR_y
outlier_y <- y[y < limite_inferiore | y > limite_superiore]
print(data.frame(
Q1 = Q1,
Q3 = Q3,
IQR = IQR_y,
Limite_inferiore = limite_inferiore,
Limite_superiore = limite_superiore,
Outlier = outlier_y
))
# Box plot singolo di y_IQ con outlier evidenziato
png("Grafici/BoxPlot/BoxPlot_y_IQ.png",
width = 1000,
height = 800)
par(mar = c(5, 5, 3, 2))
boxplot(y,
ylab = "y_IQ",
col = "lightblue",
border = "black",
outline = TRUE,
main = "")
abline(h = limite_inferiore,
col = "red",
lty = 2,
lwd = 2)
if(length(outlier_y) > 0){
points(rep(1, length(outlier_y)),
outlier_y,
col = "red",
pch = 19,
cex = 1.4)
}
legend("topright",
legend = c("Outlier", "Limite inferiore IQR"),
col = c("red", "red"),
pch = c(19, NA),
lty = c(NA, 2),
lwd = c(NA, 2),
bty = "n",
cex = 0.9)
dev.off()
# Box plot singolo per ogni variabile
for (var in variabili) {
png(paste0("Grafici/BoxPlot/BoxPlot_", var, ".png"),
width = 1000,
height = 800)
par(mar = c(5, 5, 3, 2))
boxplot(dataset[[var]],
ylab = var,
col = "lightblue",
border = "black",
outline = TRUE,
main = "")
if (var == "y_IQ") {
abline(h = limite_inferiore,
col = "red",
lty = 2,
lwd = 2)
if(length(outlier_y) > 0){
points(rep(1, length(outlier_y)),
outlier_y,
col = "red",
pch = 19,
cex = 1.4)
}
legend("topright",
legend = c("Outlier", "Limite inferiore IQR"),
col = c("red", "red"),
pch = c(19, NA),
lty = c(NA, 2),
lwd = c(NA, 2),
bty = "n",
cex = 0.9)
}
dev.off()
}
