# Impostazione cartella di lavoro
setwd("/Users/vince/Desktop/Progetto-Statistica-Appl-2025-26")
# Importazione dataset
dataset <- read.csv("Dataset_N19.csv", header = TRUE)
# Capitolo 3 - Analisi grafica dei dati
# Pulizia ambiente
rm(list = ls())
# Impostazione cartella di lavoro
setwd("/Users/vince/Desktop/Progetto-Statistica-Appl-2025-26/Gruppo19")
# Importazione dataset
dataset <- read.csv("Dataset_N19.csv", header = TRUE)
# Box plot della variabile y_IQ
y <- dataset$y_IQ
# Calcolo del criterio IQR
Q1 <- quantile(y, 0.25)
Q3 <- quantile(y, 0.75)
IQR_y <- IQR(y)
limite_inferiore <- Q1 - 1.5 * IQR_y
limite_superiore <- Q3 + 1.5 * IQR_y
# Individuazione degli outlier
outlier_y <- y[y < limite_inferiore | y > limite_superiore]
# Visualizzazione dei risultati
print(data.frame(
Q1 = Q1,
Q3 = Q3,
IQR = IQR_y,
Limite_inferiore = limite_inferiore,
Limite_superiore = limite_superiore,
Outlier = outlier_y
))
# Salvataggio del box plot della variabile y_IQ
png("Grafici/BoxPlot/BoxPlot_y_IQ.png",
width = 900,
height = 700,
res = 300)
boxplot(y,
main = "Box plot della variabile y_IQ",
ylab = "Image Quality (y_IQ)",
col = "lightblue",
border = "black",
outline = TRUE)
# Evidenzia il limite inferiore IQR
abline(h = limite_inferiore,
col = "red",
lty = 2)
# Evidenzia l'eventuale outlier
if(length(outlier_y) > 0){
points(rep(1, length(outlier_y)),
outlier_y,
col = "red",
pch = 19,
cex = 1.5)
}
legend("topright",
legend = c("Outlier", "Limite inferiore IQR"),
col = c("red", "red"),
pch = c(19, NA),
lty = c(NA, 2),
bty = "n")
dev.off()
# Box plot delle variabili indipendenti
regressori <- dataset[, c("x1_ISO", "x2_T", "x3_MP",
"x4_CF", "x5_F", "x6_GSI",
"x7_UA")]
