# ============================================================
# CAPITOLO 5 - ANALISI DI REGRESSIONE SEMPLICE
# Dataset N19 - Statistica Applicata
# ============================================================
# Pulizia ambiente
rm(list = ls())
# Impostazione cartella di lavoro
# Modifica il percorso con quello della tua cartella
# setwd("C:/Users/Angela/Desktop/Progetto_Statistica")
# Caricamento librerie
library(ggplot2)
install.packages("ggplot2")
install.packages("dplyr")
