# Introduction to R
# Fabio Postiglione (fpostiglione@unisa.it)
### Random variables
set.seed(1303) # to reproduce a specific sequence of pseudo-random numbers
rnorm(50)
set.seed (3)
y=rnorm (100)
mean(y) #[1] 0.0110
var(y) #[1] 0.7329
sqrt(var(y)) #[1] 0.8561
sd(y)
#### Graphics
x=rnorm(50)
y=x+rnorm(50,mean=50,sd=.1)
cor(x,y)
dev.new()
plot(x,y)
lm(y~x)
abline(50,0.999,col='green') # line y=a*x+b
x=rnorm(100)
y=rnorm(100)
dev.new()
plot(x,y)
plot(x,y,xlab="this is the x-axis",ylab="this is the y-axis",
main="Plot of X vs Y")
pdf("Figure.pdf")
plot(x,y,col="green")
dev.off()
png("Figure.png")
plot(x,y,col="red")
dev.off()
dev.new()
plot(x,y,xlab="this is the x-axis",ylab="this is the y-axis",
main="Plot of X vs Y")
dev.print(device=pdf, "FigBlack.pdf")
dev.new()
plot(x,y,xlab="this is the x-axis",ylab="this is the y-axis",
main="Plot of X vs Y", col="blue")
dev.print(device=jpeg, "FigBlue.jpeg",width=400,height=400)
