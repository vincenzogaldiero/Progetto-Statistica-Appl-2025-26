#Box plot
y <- dataset$y_IQ
# Calcolo del criterio IQR per y_IQ
Q1 <- quantile(y, 0.25)
Q3 <- quantile(y, 0.75)
IQR_y <- IQR(y)
limite_inferiore <- Q1 - 1.5 * IQR_y
limite_superiore <- Q3 + 1.5 * IQR_y
outlier_y <- y[y < limite_inferiore | y > limite_superiore]
print(data.frame(
Q1 = Q1,
Q3 = Q3,
IQR = IQR_y,
Limite_inferiore = limite_inferiore,
Limite_superiore = limite_superiore,
Osservazione_IQR = outlier_y
))
variabili <- c("x1_ISO", "x2_T", "x3_MP",
"x4_CF", "x5_F", "x6_GSI", "x7_UA")
# Box plot della variabile y_IQ
png("Grafici/BoxPlot/BoxPlot_y_IQ.png",
width = 1800,
height = 1400,
res = 300)
par(mar = c(5, 5, 2, 2))
boxplot(y,
ylab = "y_IQ",
col = "lightblue",
border = "black",
outline = FALSE,
main = "",
boxwex = 0.45,
cex.axis = 1.1,
cex.lab = 1.2)
if (length(outlier_y) > 0) {
points(rep(1, length(outlier_y)),
outlier_y,
col = "red3",
pch = 19,
cex = 1.5)
arrows(x0 = 1.08,
y0 = outlier_y + 5,
x1 = 1.01,
y1 = outlier_y + 0.6,
length = 0.08,
col = "red3",
lwd = 1.5)
text(1.10,
outlier_y + 5.5,
labels = "Osservazione individuata\ncon il criterio IQR",
col = "red3",
cex = 0.85,
pos = 4)
}
dev.off()
# Box plot singoli delle variabili indipendenti
for (var in variabili) {
png(paste0("Grafici/BoxPlot/BoxPlot_", var, ".png"),
width = 1200,
